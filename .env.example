# Al menos una clave de IA con facturación/cuota disponible es obligatoria.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Los modelos se prueban en secuencia para evitar multiplicar el consumo.
OPENAI_MODELS=gpt-5.6
GEMINI_MODELS=gemini-3.5-flash,gemini-2.5-flash
AI_PROVIDER_ORDER=openai,gemini
AI_MODEL_TIMEOUT_MS=52000

# Dominio público de la aplicación. Separe varios orígenes con coma.
ALLOWED_ORIGINS=https://gemini-proxy-seinca.vercel.app
RATE_LIMIT_PER_MINUTE=20
