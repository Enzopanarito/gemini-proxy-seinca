# Al menos una clave de IA es obligatoria.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Modelos separados por coma.
OPENAI_MODELS=gpt-5.6,gpt-5.6-terra,gpt-5.6-luna
GEMINI_MODELS=gemini-3.5-flash,gemini-2.5-flash,gemini-2.5-flash-lite

# Dominio público de la aplicación. Separe varios orígenes con coma.
ALLOWED_ORIGINS=https://gemini-proxy-seinca.vercel.app
RATE_LIMIT_PER_MINUTE=20
